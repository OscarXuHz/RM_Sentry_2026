<launch>

<!-- Map metadata YAML (used as standalone defaults; overridden by parent include) -->
<arg name="map_meta_file" default="$(find trajectory_generation)/map/map_meta.yaml" />
<arg name="map_resolution" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['resolution']))" />
<arg name="robot_radius" default="0.35" />
<arg name="local_v_max" default="2.0" />  <!-- was 2.8; aligned with MPC max_state_velocity_=2.5 -->
<arg name="use_omega_output" default="false" />
<arg name="map_x_size" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_x_size']))" />
<arg name="map_y_size" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_y_size']))" />
<arg name="map_lower_x" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_lower_x']))" />
<arg name="map_lower_y" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_lower_y']))" />

<node pkg="tracking_node" name="tracking_node" type="tracking_node" output="screen" required = "true">
    <remap from="/odometry_imu" to="/odom_local" />
    <remap from="/cloud_registered_world" to="/aligned_points_local" />
    <remap from="/realsense_pointcloud" to="/aligned_points_local" />
    <remap from="/mbot/velodyne_points" to="/filted_topic_3d_local" />
    <rosparam command="load" file="$(find tracking_node)/cfg/trajectory_planning.yaml" />
    <param name="tracking_node/local_v_max" value="$(arg local_v_max)"/>
    <param name="tracking_node/local_a_max" value="3.5"/>  <!-- was 6.0 — reduced to prevent aggressive acceleration -->
    <param name="tracking_node/local_w_max" value="8.0"/>
    <param name="tracking_node/local_j_max" value="8.0"/>
    <param name="tracking_node/local_vxtl_max" value="1.8"/>
    <param name="tracking_node/local_axtl_max" value="2.0"/>
    <param name="tracking_node/local_wxtl_max" value="4.0"/>
    <param name="tracking_node/local_jxtl_max" value="3.0"/>
    <param name="tracking_node/rho_" value="1.0"/>
    <param name="tracking_node/rhoN_" value="2.0"/>
    <param name="tracking_node/planning_horizon" value="20"/>
    <param name="tracking_node/dt" value="0.1"/>
<!--         <param name="tracking_node/occ_file_path" type="string" value="/home/hitcrt/sentry_ws/src/sentry_planning/trajectory_generation/map/occfinal.png"/> -->
<!--         <param name="tracking_node/bev_file_path" type="string" value="/home/hitcrt/sentry_ws/src/sentry_planning/trajectory_generation/map/bevfinal.png"/> -->
<!--         <param name="tracking_node/distance_map_file_path" type="string" value="/home/hitcrt/sentry_ws/src/sentry_planning/trajectory_generation/map/occtopo.png"/> -->
<!--         <param name="tracking_node/taskFile" type="string" value="/home/hitcrt/sentry_ws/src/sentry_planning/trajectory_tracking/cfg/task.info"/> -->
    <param name="tracking_node/occ_file_path" type="string" value="$(find trajectory_generation)/map/occfinal.png"/>
    <param name="tracking_node/bev_file_path" type="string" value="$(find trajectory_generation)/map/bevfinal.png"/>
    <param name="tracking_node/distance_map_file_path" type="string" value="$(find trajectory_generation)/map/occtopo.png"/>
    <param name="tracking_node/taskFile" type="string" value="$(find tracking_node)/cfg/task.info"/>
    <param name="tracking_node/map_resolution" value="$(arg map_resolution)"/>

    <param name="tracking_node/map_lower_point_x" value="$(arg map_lower_x)"/>
    <param name="tracking_node/map_lower_point_y" value="$(arg map_lower_y)"/>
    <param name="tracking_node/map_lower_point_z" value="0.0"/>
    <param name="tracking_node/map_x_size" value="$(arg map_x_size)"/>
    <param name="tracking_node/map_y_size" value="$(arg map_y_size)"/>
    <param name="tracking_node/map_z_size" value="2.0"/>
    <param name="tracking_node/search_height_min" value="-0.05"/>  <!-- lowered from 0.1 to catch near-ground obstacles -->
    <param name="tracking_node/search_height_max" value="1.2"/>
    <param name="tracking_node/search_radius" value="6.0"/>
    <param name="tracking_node/robot_radius_dash" value="0.35"/>  <!--仿真环境设置为0.1，因为点云没有去畸变，实际0.2-->>
    <param name="tracking_node/robot_radius" value="$(arg robot_radius)"/>
    <param name="tracking_node/use_omega_output" value="$(arg use_omega_output)"/>

    <param name="tracking_node/height_bias" value="-0.38"/>  <!-- 地图高度偏置参数-->
    <param name="tracking_node/height_interval" value="1.5"/> <!-- 地图高度间隔参数,高度地图所有像素的高度间隔-->
    <param name="tracking_node/height_threshold" value="0.08"/> <!-- lowered from 0.15 to detect low ground obstacles -->
    <param name="tracking_node/height_sencond_high_threshold" value="0.3"/> <!-- 桥梁地图高度阈值参数,这个是顶部高度阈值-->





</node>

</launch>

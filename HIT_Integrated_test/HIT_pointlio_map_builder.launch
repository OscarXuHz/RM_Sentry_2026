<launch>
    <!--
    HIT Integration Point-LIO Map Builder
    
    Builds a 3D point cloud map using Point-LIO and saves it as scans.pcd
    in /home/sentry/AstarTraining/RM_Sentry_2026/HIT_Integrated_test/pcd/.
    
    After the map is built (Ctrl-C to stop), the operator inspects the output
    and renames it to current.pcd if acceptable:
    
        cd /home/sentry/AstarTraining/RM_Sentry_2026/HIT_Integrated_test/pcd
        mv scans.pcd current.pcd
        # Then run pcd_to_maps.py to regenerate planner map products
    
    Floor leveling (fixes P1 — negative Z, and P2 — XY tilt):
      When pcd_save/level_floor is true (default), Point-LIO post-processes
      the saved PCD to:
        1. Detect floor points using a Z-quantile threshold
        2. Fit a floor plane via PCA and rotate the cloud so floor is level
        3. Shift Z so the floor median sits at floor_target_z (default 0.0)
    
    Prerequisites:
        source /home/sentry/AstarTraining/RM_Sentry_2026/HIT_Integrated_test/hit_env.bash
    
    Usage:
        roslaunch /home/sentry/AstarTraining/RM_Sentry_2026/HIT_Integrated_test/HIT_pointlio_map_builder.launch
        roslaunch ... enable_rviz:=true   # to visualise during mapping
    -->

    <arg name="enable_rviz" default="false" />
    <arg name="pcd_output" default="/home/sentry/AstarTraining/RM_Sentry_2026/HIT_Integrated_test/pcd/scans.pcd" />
    <arg name="floor_quantile" default="0.08" doc="Fraction of lowest-Z points used as floor for PCA (0.08 = bottom 8%%)" />
    <arg name="floor_target_z" default="0.0" doc="Target Z height for floor after normalization" />
    <arg name="min_floor_points" default="1000" doc="Minimum floor points required for normalization safety check" />
    <arg name="pca_max_iterations" default="5" doc="Max PCA floor-leveling passes (default 5; converges early if tilt &lt; 0.005 deg)" />
    <arg name="lidar_height" default="0.3" doc="LiDAR mounting height above floor (m). Shifts z=0 to the floor plane." />
    <arg name="z_floor"   default="-0.5" doc="Discard points with Z below this height (metres) when saving PCD" />
    <arg name="z_ceiling" default="0.4"  doc="Discard points with Z above this height (metres) when saving PCD" />

    <!-- 1) Livox driver -->
    <include file="$(find livox_ros_driver2)/launch_ROS1/msg_mixed.launch" />

    <!-- 2) Merge two Livox pointclouds into /3Dlidar -->
    <include file="$(find bot_sim)/launch_real/lidar_merge_pointcloud.launch" />

    <!-- 3) Point-LIO SLAM — produces the map on shutdown -->
    <node pkg="point_lio" type="pointlio_mapping" name="laserMapping" output="screen">
        <!-- Load base config (topics, IMU, extrinsics, etc.) -->
        <rosparam command="load" file="$(find point_lio)/config/avia.yaml" />

        <!-- Core Point-LIO tuning (mirror mapping_avia.launch) -->
        <param name="use_imu_as_input" type="bool" value="1"/>
        <param name="prop_at_freq_of_imu" type="bool" value="1"/>
        <param name="check_satu" type="bool" value="1"/>
        <param name="init_map_size" type="int" value="10"/>
        <param name="point_filter_num" type="int" value="1"/>
        <param name="space_down_sample" type="bool" value="1" />
        <param name="filter_size_surf" type="double" value="0.3" />
        <param name="filter_size_map" type="double" value="0.2" />
        <param name="cube_side_length" type="double" value="2000" />
        <param name="runtime_pos_log_enable" type="bool" value="0" />

        <!-- PCD save: one combined file on shutdown, then level the floor -->
        <param name="pcd_save/pcd_save_en" value="true" />
        <param name="pcd_save/interval" value="-1" />
        <param name="pcd_save/output_path" value="$(arg pcd_output)" />

        <!-- Floor leveling — fixes P1 (negative Z) and P2 (XY tilt) -->
        <param name="pcd_save/level_floor" value="true" />
        <param name="pcd_save/floor_quantile" value="$(arg floor_quantile)" />
        <param name="pcd_save/floor_target_z" value="$(arg floor_target_z)" />
        <param name="pcd_save/min_floor_points" value="$(arg min_floor_points)" />
        <param name="pcd_save/pca_max_iterations" value="$(arg pca_max_iterations)" />
        <param name="mapping/lidar_height" type="double" value="$(arg lidar_height)" />
        <param name="pcd_save/z_floor"   type="double" value="$(arg z_floor)" />
        <param name="pcd_save/z_ceiling" type="double" value="$(arg z_ceiling)" />
    </node>

    <group if="$(arg enable_rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz"
              args="-d $(find point_lio)/rviz_cfg/loam_livox.rviz" />
    </group>
</launch>

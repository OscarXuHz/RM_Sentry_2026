<launch>
    <!-- Ensure HIT planning workspace is on ROS_PACKAGE_PATH -->
    <env name="ROS_PACKAGE_PATH" value="/home/sentry/AstarTraining/DecisionNode/src:/home/sentry/AstarTraining/RM_Sentry_2026/HIT_code/sentry_planning_ws/src:$(env ROS_PACKAGE_PATH)" />
    <!-- DecisionNode devel space needed for mcu_communicator executable discovery -->
    <env name="CMAKE_PREFIX_PATH" value="/home/sentry/AstarTraining/DecisionNode/devel:$(env CMAKE_PREFIX_PATH)" />
    <!-- HIT integration args -->
    <!-- Map metadata YAML generated by pcd_to_maps.py; all map params default from this file -->
    <arg name="map_meta_file" default="$(find trajectory_generation)/map/map_meta.yaml" doc="Path to map_meta.yaml generated by pcd_to_maps.py" />
    <arg name="map_resolution" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['resolution']))" />
    <arg name="robot_radius" default="0.35" />
    <arg name="reference_desire_speed" default="2.0" />  <!-- was 2.8 — reduced to prevent wall crashes -->
    <arg name="local_v_max" default="2.0" />              <!-- was 2.8 -->
    <arg name="points_topic" default="/livox/lidar" />
    <arg name="enable_rviz" default="false" />
    <arg name="enable_ser2msg" default="false" />
    <arg name="enable_real_robot_transform" default="true" />
    <arg name="enable_dstarlite" default="false" />
    <arg name="enable_map_server" default="false" doc="Legacy 2D map_server (/map). Not required for default HIT stack." />
    <arg name="serial_port" default="/dev/ttyUSB0" />
    <arg name="serial_baudrate" default="921600" />
    <arg name="enable_mcu_communicator" default="true" doc="Set false when MCU serial is not connected" />
    <arg name="map_x_size"  default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_x_size']))" doc="Map extent X in metres (from map_meta.yaml)" />
    <arg name="map_y_size"  default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_y_size']))" doc="Map extent Y in metres (from map_meta.yaml)" />
    <arg name="map_lower_x" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_lower_x']))" doc="Map origin X (lower-left corner, from map_meta.yaml)" />
    <arg name="map_lower_y" default="$(eval float(dict(l.strip().split(': ', 1) for l in open(arg('map_meta_file')) if ': ' in l and not l.startswith('#'))['map_lower_y']))" doc="Map origin Y (lower-left corner, from map_meta.yaml)" />
    <!-- 1. 2D map_server（legacy，仅 D* Lite 或老模块需要 /map 时启用） -->
    <include file="$(find bot_sim)/launch_real/map_server.launch"
             if="$(eval arg('enable_map_server') == 'true' or arg('enable_dstarlite') == 'true')" />

    <!-- 2. IMU 滤波（无需改动） -->
    <include file="$(find bot_sim)/launch_real/imu_filter.launch" />

    <!-- 3. 激光驱动：rviz_MID360.launch uses MID360_config.json (single lidar, roll=20°).
         xfer_format=0 (PointCloud2), msg_frame_id=aft_mapped — matches Old_nav.
         hdl_localization subscribes to /livox/lidar as PointCloud2 directly.
         rviz disabled (headless NUC — no display server). -->
    <include file="$(find livox_ros_driver2)/launch_ROS1/rviz_MID360.launch">
        <arg name="rviz_enable" value="false"/>
        <arg name="msg_frame_id" value="aft_mapped"/>
    </include>
 
    <!-- 4. 定位（对齐 3DNavUL_Test.launch） -->
    <include file="$(find hdl_localization)/launch/hdl_localization.launch">
        <arg name="points_topic" value="$(arg points_topic)" />
        <arg name="invert_imu_acc" value="true" />
    </include>

    <!-- 5. TF 变换（对齐 3DNavUL_Test.launch） -->
    <include file="$(find bot_sim)/launch_real/real_robot_transform.launch" if="$(arg enable_real_robot_transform)" />

    <!-- 6. 点云滤波（disabled: following Old_nav pipeline — no filter/merger.
         livox_cloudpoint_processor expects CustomMsg but driver publishes PointCloud2.
         Re-enable when filter is needed for /grid output to HIT planners.) -->
    <!-- <include file="$(find livox_cloudpoint_processor)/launch/lidar_filter_pointcloud.launch" /> -->

    <!-- 7. D* Lite（禁用，使用 HIT 规划与跟踪） -->
    <include file="$(find bot_sim)/launch_real/dstarlite.launch" if="$(arg enable_dstarlite)" />

    <!-- 8. 添加 HIT 全局规划 -->
    <include file="$(find trajectory_generation)/launch/global_searcher.launch">
        <arg name="map_resolution" value="$(arg map_resolution)"/>
        <arg name="robot_radius" value="$(arg robot_radius)"/>
        <arg name="reference_desire_speed" value="$(arg reference_desire_speed)"/>
        <arg name="enable_rviz" value="$(arg enable_rviz)" />
        <arg name="map_x_size" value="$(arg map_x_size)" />
        <arg name="map_y_size" value="$(arg map_y_size)" />
        <arg name="map_lower_x" value="$(arg map_lower_x)" />
        <arg name="map_lower_y" value="$(arg map_lower_y)" />
    </include>

    <!-- 8.1 目标与里程计坐标系归一化（输出 /odom_local 与 /clicked_point） -->
    <node pkg="bot_sim" type="local_frame_bridge.py" name="local_frame_bridge" output="screen">
        <param name="odom_topic" value="/odom" />
        <param name="odom_local_topic" value="/odom_local" />
        <param name="goal_topic" value="/move_base_simple/goal" />
        <param name="clicked_topic" value="/clicked_point" />
        <param name="frame_id" value="map" />
        <param name="aligned_in" value="/aligned_points" />
        <param name="aligned_out" value="/aligned_points_local" />
        <param name="filtered_in" value="/filted_topic_3d" />
        <param name="filtered_out" value="/filted_topic_3d_local" />
        <param name="center_on_first_odom" value="false" />
        <param name="passthrough" value="true" />
        <param name="map_size_x" value="$(arg map_x_size)" />
        <param name="map_size_y" value="$(arg map_y_size)" />
        <param name="map_lower_x" value="$(arg map_lower_x)" />
        <param name="map_lower_y" value="$(arg map_lower_y)" />
    </node>

    <!-- 9. 添加 HIT 局部跟踪 -->
    <include file="$(find tracking_node)/launch/trajectory_planning.launch">
        <arg name="map_resolution" value="$(arg map_resolution)"/>
        <arg name="robot_radius" value="$(arg robot_radius)"/>
        <arg name="local_v_max" value="$(arg local_v_max)"/>
        <arg name="map_x_size" value="$(arg map_x_size)"/>
        <arg name="map_y_size" value="$(arg map_y_size)"/>
        <arg name="map_lower_x" value="$(arg map_lower_x)"/>
        <arg name="map_lower_y" value="$(arg map_lower_y)"/>
    </include>

    <!-- 9.5 BEV map visualization in RViz -->
    <node pkg="bot_sim" type="map_image_publisher.py" name="bev_image_publisher" output="log">
        <param name="image_path" value="$(find trajectory_generation)/map/bevfinal.png" />
        <param name="resolution" value="$(arg map_resolution)" />
        <param name="origin_x" value="$(arg map_lower_x)" />
        <param name="origin_y" value="$(arg map_lower_y)" />
        <param name="frame_id" value="map" />
        <param name="rate" value="1.0" />
        <param name="invert" value="true" />
    </node>

    <!-- 9.6 OCC map visualization in RViz -->
    <node pkg="bot_sim" type="map_image_publisher.py" name="occ_image_publisher" output="log">
        <param name="image_path" value="$(find trajectory_generation)/map/occfinal.png" />
        <param name="resolution" value="$(arg map_resolution)" />
        <param name="origin_x" value="$(arg map_lower_x)" />
        <param name="origin_y" value="$(arg map_lower_y)" />
        <param name="frame_id" value="map" />
        <param name="rate" value="1.0" />
        <param name="invert" value="false" />
    </node>

    <!-- 9.7 TOPO map visualization in RViz -->
    <node pkg="bot_sim" type="map_image_publisher.py" name="topo_image_publisher" output="log">
        <param name="image_path" value="$(find trajectory_generation)/map/occtopo.png" />
        <param name="resolution" value="$(arg map_resolution)" />
        <param name="origin_x" value="$(arg map_lower_x)" />
        <param name="origin_y" value="$(arg map_lower_y)" />
        <param name="frame_id" value="map" />
        <param name="rate" value="1.0" />
        <param name="invert" value="false" />
    </node>

    <!-- 10. HIT velocity bridge: slaver_speed → Twist → serial MCU (0x93 CRC8) -->
    <!-- 10a. hit_bridge passes /sentry_des_speed (slaver_speed) directly to /cmd_vel (Twist)
              and publishes arrival flag on /dstar_status (Bool) -->
    <node pkg="tracking_node" type="hit_bridge" name="hit_bridge" output="screen">
        <param name="cmd_vel_topic"  value="/cmd_vel" />
        <param name="speed_topic"    value="/sentry_des_speed" />
        <param name="arrived_topic"  value="/dstar_status" />
    </node>

    <!-- 10b. mcu_communicator: HK protocol serial bridge
              TX: 21B NavigationCommandFrame @ 50Hz (vx/vy mm/s, wz 0.01rad/s, heroes_never_die)
              RX: 78B HK game data frame (referee, HP, enemy positions, revive status) -->
    <node pkg="decision_node" type="mcu_communicator" name="mcu_communicator" output="screen"
          if="$(arg enable_mcu_communicator)">
        <param name="serial_port" value="$(arg serial_port)" />
        <param name="baudrate"    value="$(arg serial_baudrate)" />
        <param name="nav_frequency" value="50.0" />
    </node>

    <!-- 10c. Legacy ser2msg kept behind flag for fallback (default OFF) -->
    <include file="$(find bot_sim)/launch_real/ser2msg_tf_decision_givepoint.launch" if="$(arg enable_ser2msg)">
        <param name="vel_topic" value="/sentry_des_speed" />
    </include>
</launch>
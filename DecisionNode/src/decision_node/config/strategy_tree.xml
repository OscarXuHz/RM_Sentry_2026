<root BTCPP_format="4">
  <BehaviorTree ID="Main">
    <ReactiveSequence name="MainLoop">
      <Sequence name="UpdateBlackboard">
        <UpdateRefereeBB />
        <UpdateNavigationBB />
        <UpdateVisionBB />
        <UpdateTimersBB />
        <UpdateDerivedFlags danger_hp="{danger_hp}" sufficient_bullet="{sufficient_bullet}" />
      </Sequence>

      <ReactiveFallback name="DecideAction">
        <Sequence name="ToInitWhenNotInGame">
          <IsGameStarted expect_started="false" />
          <ResetCentralOccupiable />
          <SetAction action="INIT" />
        </Sequence>

        <Sequence name="ToPushWhenGameStart">
          <IsGameStarted expect_started="true" />
          <IsAction value="INIT" />
          <SetAction action="INITPUSH" />
        </Sequence>

        <Sequence name="ToRespawnWhenDead">
          <IsSentryDead />
          <SetAction action="RESPAWN" />
        </Sequence>

        <Sequence name="ToSupplyAfterRespawn">
          <IsAction value="RESPAWN" />
          <IsSentryAlive />
          <SetAction action="SUPPLY" />
        </Sequence>

        <Sequence name="ToSupplyWhenInDanger">
          <IsSentryInDanger />
          <SetAction action="SUPPLY" />
        </Sequence>

        <Sequence name="MaintainSupply">
          <IsAction value="SUPPLY" />
          <Inverter>
            <IsHealthFull />
          </Inverter>
          <SetAction action="SUPPLY" />
        </Sequence>

        <Sequence name="SwitchPushToOccupy">
          <Fallback>
            <IsAction value="PUSH" />
            <IsAction value="INITPUSH" />
          </Fallback>
          <CheckArrived />
          <SetAction action="OCCUPY" />
        </Sequence>

        <Fallback name="ToPush">
          <Sequence name="SafePush">
            <Sequence>
              <AccumulateCentralOccupiable 
                occupy_status="{ref.occupy_status}"
                threshold="{occupy_threshold}"
                accumulated_count="{occupy_count}"
                reached_threshold="{occupy_reached}" />
              <TriggerOnThreshold 
                reached_threshold="{occupy_reached}"
                reset_condition="{is_enemy_occupied}" />
            </Sequence>
            <SetAction action="PUSH" />
            <ResetAccumulator />
          </Sequence>
          
          <Sequence name="AggressiveOccupy">
            <NotBulletSufficient />
            <AggressiveAdvantage threshold="{aggressive_threshold}" />
            <SetAction action="PUSH"/>  
          </Sequence>
        </Fallback>
    
        <Sequence name="ToRadicalWhenAggressiveAndBulletSufficient">
          <AggressiveAdvantage threshold="50" />
          <Inverter>
            <NotBulletSufficient />
          </Inverter>
          <SetAction action="RADICAL" />
        </Sequence>
      
        <Sequence name="MaintainPushwhenStart">
          <IsAction value="INITPUSH" />
          <SetAction action="INITPUSH" />
        </Sequence>

        <Sequence name="MaintainOccupy">
          <IsAction value="OCCUPY" />
          <SetAction action="OCCUPY" />
        </Sequence>

        <!-- Default state -->
        <Sequence name="ToWaitforOP">
          <SetAction action="WAITFOROP" />
        </Sequence>
      </ReactiveFallback>

      <ReactiveFallback name="ExecuteAction">
        <Sequence>
          <IsAction value="INIT" />
          <SetMotionFlag target_motion="0" />
          <PublishMotion />
          <SetBulletUp value="0" />
          <PublishBulletUp />
          <SetRecover value="0" />
          <PublishRecover />
          <ClearGoal />
        </Sequence>

        <Sequence>
          <Fallback>
            <IsAction value="PUSH" />
            <IsAction value="INITPUSH" />
          </Fallback>
          <!-- Navigate to first cycle point (moving state) -->
          <SetMotionFlag target_motion="3" />
          <PublishMotion />
          <SetGoalFromParamsCyclic ns="occupy" point_count="4" />
          <PublishGoalPoint topic="clicked_point" />
          <Sequence>
              <CheckArrived />
              <SetAction action="OCCUPY"/>
              <AlwaysSuccess />
          </Sequence>
        </Sequence>

        <Sequence>
          <IsAction value="OCCUPY" />
          <Fallback>
            <Sequence>
              <CheckArrived />
              <AdvanceCycleIndex point_count="4" /> 
            </Sequence>
            <AlwaysSuccess />
          </Fallback>
          <Fallback>
            <Sequence>
              <CheckAttacked attack_threshold="{attack_threshold}" />
              <SetMotionFlag target_motion="2" />
            </Sequence>
            <SetMotionFlag target_motion="1" />
          </Fallback>
          <PublishMotion />
          <SetGoalFromParamsCyclic ns="occupy" point_count="4" />
          <PublishGoalPoint topic="clicked_point" />
        </Sequence>

        <Sequence>
          <IsAction value="SUPPLY" />
          <SetMotionFlag target_motion="3" />
          <PublishMotion />
          <SetGoalFromParams ns="supply" />
          <PublishGoalPoint topic="clicked_point" />
          <Fallback>
            <Sequence>
              <CheckArrived />
              <SetRecover value="1" />
              <PublishRecover />
            </Sequence>
            <AlwaysSuccess />
          </Fallback>
          <Fallback>
            <Sequence>
              <IsHealthFull />
              <SetRecover value="0" />
              <PublishRecover />
            </Sequence>
            <AlwaysSuccess />
          </Fallback>
          <Fallback>
            <Sequence>
              <CheckArrived />
              <SetBulletUp value="1" />
              <PublishBulletUp />
              <SetBulletNum mode="DELTA" expected_bullet="{max_bullet}" fixed_supply="{fixed_supply}" />
              <PublishBulletNum />
            </Sequence>
            <AlwaysSuccess />
          </Fallback>
          <Fallback>
            <Sequence>
              <IsBulletFull max_bullet="{max_bullet}" />
              <SetBulletUp value="0" />
              <SetBulletNum mode="FIXED" fixed_supply="0" />
              <PublishBulletUp />
              <PublishBulletNum />
            </Sequence>
            <AlwaysSuccess />
          </Fallback>
        </Sequence>

        
        <Sequence>
          <IsAction value="RADICAL" />
          <InitChase />
          <UpdateChaseTarget />
          <!-- TODO: 接入视觉模块 -->
          <SetMotionFlag target_motion="1" />
          <PublishMotion />
          <PublishChaseGoal />
        </Sequence>
      

        <Sequence>
          <IsAction value="RESPAWN" />
          <SetMotionFlag target_motion="0" />
          <PublishMotion />
        </Sequence>

        <Sequence>
          <IsAction value="WAITFOROP" />
          <SetMotionFlag target_motion="3" />
          <PublishMotion />
          <SetBulletUp value="0" />
          <PublishBulletUp />
          <SetRecover value="0" />
          <PublishRecover />
          
          <Fallback>
            <Sequence>
                <IntenseHarm 
                   threshold_activate="{harm_threshold_on}" 
                   threshold_deactivate="{harm_threshold_off}" />
                <SetGoalFromParams ns="retreat" />
            </Sequence>
            <SetGoalFromParams ns="waitforop" />
          </Fallback>

          <PublishGoalPoint topic="clicked_point" />
        </Sequence>
      </ReactiveFallback>
    </ReactiveSequence>
  </BehaviorTree>
</root>